{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "wal-presync",
            "type": "command",
            "command": "FERROFACTION_BUCKET=gs://ferrofaction-test/agent FERROFACTION_LOCAL_STATE=${HOME}/.gemini/tmp/ferrofaction/chats /Users/danielhumphries/src/ferrofaction/scripts/wal-sync.sh"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "wal-postsync",
            "type": "command",
            "command": "FERROFACTION_BUCKET=gs://ferrofaction-test/agent FERROFACTION_LOCAL_STATE=${HOME}/.gemini/tmp/ferrofaction/chats /Users/danielhumphries/src/ferrofaction/scripts/wal-sync.sh"
          }
        ]
      }
    ]
  }
}
